# Copy this file to .env (local dev) and set real values in your host's secret
# manager for staging/production. Never commit a filled-in .env file.

# --- Database ---------------------------------------------------------------
DATABASE_URL="postgresql://trackmysugar:trackmysugar_dev_only@localhost:5432/trackmysugar?schema=public"

# --- App-level encryption ----------------------------------------------------
# AES-256-GCM key (32 bytes) used to encrypt Dexcom OAuth tokens before they're
# written to the database. Generate with: openssl rand -base64 32
# Rotate by re-encrypting existing rows; losing this key makes stored tokens
# unrecoverable (patients would need to reconnect Dexcom).
APP_ENCRYPTION_KEY="replace-with-openssl-rand--base64-32-output"

# --- Dexcom API ---------------------------------------------------------------
# Register an app at https://developer.dexcom.com to get these.
# "sandbox" hits https://sandbox-api.dexcom.com with Dexcom's fake test users;
# "production" hits https://api.dexcom.com and requires an approved Dexcom
# developer partnership before it will work with real patient accounts.
DEXCOM_ENVIRONMENT="sandbox"
DEXCOM_CLIENT_ID="replace-with-dexcom-client-id"
DEXCOM_CLIENT_SECRET="replace-with-dexcom-client-secret"
DEXCOM_REDIRECT_URI="http://localhost:3000/api/dexcom/callback"

# --- Background sync ----------------------------------------------------------
# Bearer token an external scheduler (cron, GitHub Actions, Vercel Cron, etc.)
# must present to trigger POST /api/cron/daily-sync. Generate with:
# openssl rand -hex 32
CRON_SECRET="replace-with-openssl-rand-hex-32-output"

# --- Sessions -------------------------------------------------------------
# How long a staff login session may go idle before it's invalidated.
SESSION_IDLE_TIMEOUT_MINUTES="30"

# --- CDCES call talking points (optional) ------------------------------------
# If set, "Initiate call" generates AI talking points via the Anthropic API
# from the patient's stats (glucose, TIR, R30, streak, diagnosis, devices).
# If unset, a deterministic rule-based summary is used instead — the call
# workflow works either way. Sending patient data to an LLM API is a PHI
# disclosure: see docs/HIPAA.md before enabling this with real patient data.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
