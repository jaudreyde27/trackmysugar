// Prisma schema for the trackmysugar clinic dashboard.
// See /docs/HIPAA.md for the compliance rationale behind the audit/session/encryption models.

generator client {
  // Deliberately the default node_modules/@prisma/client output, imported
  // as "@prisma/client" everywhere — Next.js has built-in special handling
  // (serverExternalPackages) that correctly bundles Prisma's native engine
  // binary for serverless deployment only when it's at this conventional
  // location. A custom output path (what this used to be) bypasses that
  // handling, gets bundled as regular source by Turbopack, and breaks
  // Prisma's runtime-relative engine lookup on Vercel.
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  ADMIN
  CLINICIAN
}

// Which portal a non-platform-admin staff account lands in. Practice and
// CDCES share the same routes (roster, patient detail) — this only gates
// which capabilities render/are permitted, not which URLs exist. A third
// portal (platform-admin account management) is handled separately via
// StaffUser.isPlatformAdmin, not this enum.
enum PortalType {
  PRACTICE
  CDCES
}

enum DiabetesType {
  TYPE_1
  TYPE_2
}

enum CgmDevice {
  DEXCOM
  FREESTYLE_LIBRE
}

enum InsulinDeliveryDevice {
  OMNIPOD
  TANDEM
  MEDTRONIC
  MDI
}

enum DeviceCategory {
  CGM
  PUMP
}

enum PhoneType {
  MOBILE
  HOME
  WORK
}

enum InsuranceRank {
  PRIMARY
  SECONDARY
}

enum SubscriberRelationship {
  SELF
  SPOUSE
  CHILD
  OTHER
}

enum DexcomEnvironment {
  SANDBOX
  PRODUCTION
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  ERROR
  REVOKED
}

enum SyncRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum EgvTrend {
  NONE
  DOUBLE_UP
  SINGLE_UP
  FORTY_FIVE_UP
  FLAT
  FORTY_FIVE_DOWN
  SINGLE_DOWN
  DOUBLE_DOWN
  NOT_COMPUTABLE
  RATE_OUT_OF_RANGE
}

// CALL: created by the live "Start CDCES call" flow (has startedAt/endedAt,
// talkingPoints). NOTE: created via the Notes panel composer, optionally
// with Min/Sec monitoring time attached. MANUAL: logged directly on the
// Monitoring tab's standalone time-entry form. All three roll up into the
// same monthly compliance/billing totals.
enum MonitoringSessionSource {
  CALL
  NOTE
  MANUAL
}

model StaffUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         StaffRole  @default(CLINICIAN)
  portalType   PortalType @default(PRACTICE)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Fixed home org for PRACTICE-portal staff — null for platform-admin
  // accounts (which sit above any single clinic) *and* for CDCES-portal
  // staff, who instead get one-or-more practices via organizationAccess
  // below and whichever one is currently active lives on their Session
  // row. `role` (ADMIN/CLINICIAN) is a separate, clinic-scoped permission,
  // orthogonal to both portalType and isPlatformAdmin.
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  isPlatformAdmin Boolean       @default(false)

  // CDCES-portal staff only — which practices they're allowed to view/act
  // in. Managed by a future Admin View; seeded directly for now.
  organizationAccess StaffOrganizationAccess[]

  sessions                Session[]
  auditLogs               AuditLog[]
  monitoringSessions      MonitoringSession[]
  billedPeriods           BillingPeriodStatus[]
  generatedBillingBatches BillingBatch[]

  @@index([organizationId])
  @@map("staff_users")
}

// Many-to-many grant of CDCES-portal staff to practices — what a future
// Admin View will manage, and what the practice switcher reads from.
// PRACTICE-portal staff don't use this; they stay on StaffUser.organizationId.
model StaffOrganizationAccess {
  id             String   @id @default(cuid())
  staffUserId    String
  staffUser      StaffUser    @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([staffUserId, organizationId])
  @@index([organizationId])
  @@map("staff_organization_access")
}

// A single clinic/practice using the platform. Single-tenant in practice
// today (one seeded org), but every clinic-facing query is scoped through
// this from day one so multi-org support later is additive, not a retrofit.
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Medical-necessity/consent language used on the audit report's RPM
  // Consent section. A legal template field, not hardcoded copy — null
  // renders a clearly-labeled placeholder pending legal/compliance review.
  rpmConsentTemplate String?

  // Billing-entity identity stamped onto every RPM billing batch line
  // generated for this practice (Box 33 on a CMS-1500) — one billing
  // entity per practice, distinct from any individual rendering provider.
  billingProviderName  String?
  billingProviderNpi   String?
  billingProviderTaxId String?

  staffUsers         StaffUser[]
  patients           Patient[]
  staffAccess        StaffOrganizationAccess[]
  selectedInSessions Session[]
  billingBatches     BillingBatch[]
  rpmBillingLines    RpmBillingLine[]
  rpmExclusions      RpmExclusion[]

  @@map("organizations")
}

model Session {
  id            String   @id @default(cuid())
  staffUserId   String
  staffUser     StaffUser @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
  tokenHash     String    @unique
  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())
  expiresAt     DateTime
  ipAddress     String?
  userAgent     String?
  revokedAt     DateTime?

  // CDCES-portal only — which of the staff user's accessible practices is
  // currently active for this session (the practice switcher writes this).
  // Set once at login and only ever changed by an explicit switch, never
  // lazily defaulted-and-rewritten on every request.
  selectedOrganizationId String?
  selectedOrganization   Organization? @relation(fields: [selectedOrganizationId], references: [id], onDelete: SetNull)

  @@index([staffUserId])
  @@map("sessions")
}

model Patient {
  id           String       @id @default(cuid())
  mrn          String       @unique
  firstName    String
  lastName     String
  dateOfBirth  DateTime     @db.Date
  sex          String?
  diabetesType DiabetesType
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Date the patient was enrolled in the practice's CGM monitoring program
  // (not necessarily the same as when their record was created here).
  enrolledAt DateTime @db.Date

  // Primary ICD-10 diagnosis code, e.g. "E10.9" (Type 1) or "E11.9" (Type 2).
  primaryDiagnosisCode  String
  cgmDevice             CgmDevice?
  insulinDeliveryDevice InsulinDeliveryDevice?

  // Name of the in-practice provider (endocrinologist/APP) the patient
  // usually sees — a plain display field, not linked to StaffUser, since
  // the prescribing provider doesn't necessarily have a dashboard login.
  primaryProviderName String?
  // The billing/overseeing provider for RPM CPT codes — often distinct
  // from the referring/primary provider above.
  supervisingProviderName String?
  // Rendering-provider NPI stamped onto every RPM billing batch line —
  // always the supervising physician's, per the general-supervision
  // billing model, never the CDCES-RN who actually performed the work.
  supervisingProviderNpi String?
  careManagerName        String?

  // Short standing clinical note shown on the summary card — distinct from
  // the chronological visit-notes log (MonitoringSession.notes).
  clinicalNotes String?

  // One-time RPM setup/education checkoff (CPT 99453) — unlike the other
  // billing codes, this doesn't recompute monthly once done.
  cpt99453CompletedAt DateTime?
  // Distinct from cpt99453CompletedAt above: that's "is the one-time setup
  // clinically done" (a staff-toggled checkbox); this is "has 99453 ever
  // actually been included in a generated RPM billing batch." A batch only
  // includes 99453 when the former is set AND this is still false, then
  // sets this true — monotonically, never reset — so regenerating a period
  // after 99453 was already billed once never re-bills it.
  rpmSetupBilled Boolean @default(false)
  consentDate    DateTime? @db.Date

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Contact info
  email              String?
  phoneMobile        String?
  phoneHome          String?
  phoneWork          String?
  preferredPhoneType PhoneType?
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  postalCode         String?

  dexcomConnection      DexcomConnection?
  glucoseReadings       GlucoseReading[]
  syncDays              SyncDay[]
  auditLogs             AuditLog[]
  monitoringSessions    MonitoringSession[]
  medications           Medication[]
  insurancePolicies     InsurancePolicy[]
  deviceHistory         DeviceHistory[]
  billingPeriodStatuses BillingPeriodStatus[]
  rpmBillingLines       RpmBillingLine[]
  rpmExclusions         RpmExclusion[]

  @@index([organizationId])
  @@map("patients")
}

// One row per device a patient has used (CGM or pump), so the patient page
// can show "Start Month/Year - Present or End Month/Year" per device rather
// than only the single currently-active device on the Patient record.
model DeviceHistory {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  category              DeviceCategory
  cgmDevice             CgmDevice?
  insulinDeliveryDevice InsulinDeliveryDevice?
  serialNumber          String?

  startedAt DateTime  @db.Date
  endedAt   DateTime? @db.Date

  createdAt DateTime @default(now())

  @@index([patientId, category, startedAt])
  @@map("device_history")
}

// Read-only for now, like Medication — captures what's needed to file a
// claim (payer, member/group IDs, subscriber) without collecting SSN, which
// isn't required for billing in the vast majority of modern payer workflows.
model InsurancePolicy {
  id        String        @id @default(cuid())
  patientId String
  patient   Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  rank      InsuranceRank

  payerName    String
  memberId     String
  groupNumber  String?
  planType     String?

  subscriberName         String?
  subscriberRelationship SubscriberRelationship @default(SELF)
  effectiveDate          DateTime?              @db.Date

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, rank])
  @@map("insurance_policies")
}

// Read-only for now (see docs) — a staff-facing add/edit workflow can follow
// once medication reconciliation is actually needed.
model Medication {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  name      String
  dosage    String?
  frequency String?
  active    Boolean  @default(true)
  startedAt DateTime? @db.Date

  createdAt DateTime @default(now())

  @@index([patientId])
  @@map("medications")
}

model DexcomConnection {
  id     String @id @default(cuid())
  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  environment DexcomEnvironment @default(SANDBOX)
  status      ConnectionStatus  @default(PENDING)

  encryptedAccessToken  String?
  encryptedRefreshToken String?
  accessTokenExpiresAt  DateTime?
  scope                 String?

  lastSyncAttemptAt DateTime?
  lastSyncSuccessAt DateTime?
  lastError         String?

  connectedAt DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("dexcom_connections")
}

model GlucoseReading {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  systemTime  DateTime
  displayTime DateTime
  value       Int
  unit        String   @default("mg/dL")
  trend       EgvTrend @default(NONE)
  trendRate   Float?

  createdAt DateTime @default(now())

  @@unique([patientId, systemTime])
  @@index([patientId, displayTime])
  @@map("glucose_readings")
}

// One row per patient per calendar day; the source of truth for the
// "days with data transmitted" ticker on the patient page.
model SyncDay {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  date         DateTime @db.Date
  hasData      Boolean  @default(false)
  readingCount Int      @default(0)
  syncedAt     DateTime @default(now())

  @@unique([patientId, date])
  @@index([patientId, date])
  @@map("sync_days")
}

// One row per execution of the daily sync job (across all patients).
model SyncRun {
  id        String        @id @default(cuid())
  startedAt DateTime      @default(now())
  finishedAt DateTime?
  status    SyncRunStatus @default(RUNNING)

  patientsProcessed Int @default(0)
  patientsSucceeded Int @default(0)
  patientsFailed    Int @default(0)

  errorSummary String?

  @@map("sync_runs")
}

// A single loggable clinician touchpoint with a patient — a live CDCES call,
// a standalone note from the Notes panel, or a manual entry from the
// Monitoring tab. This is the single source of truth for both the "Last
// CDCES touchpoint" date and every monitoring-time/billing rollup (RPM CPT
// eligibility, compliance history) — every entry point writes here so
// there's one rollup to compute rather than three.
model MonitoringSession {
  id          String    @id @default(cuid())
  patientId   String
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  staffUserId String
  staffUser   StaffUser @relation(fields: [staffUserId], references: [id])

  source MonitoringSessionSource @default(NOTE)

  // Live call tracking (CALL source only) — endedAt null means still active.
  startedAt DateTime?
  endedAt   DateTime?

  // The date/time this entry counts toward for compliance/billing — equals
  // startedAt for CALL rows; an explicit date/time-picker value otherwise.
  occurredAt DateTime @default(now())

  durationSeconds Int @default(0)

  notes               String  @default("")
  templateUsed        String?
  twoWayCommunication Boolean @default(false)

  // Snapshot of the AI-generated (or rule-based fallback) talking points
  // shown at call start (CALL source only); not regenerated mid-call.
  talkingPoints String?

  createdAt DateTime @default(now())

  @@index([patientId, occurredAt])
  @@index([patientId, source, endedAt])
  @@map("monitoring_sessions")
}

// One row per patient per billing month — tracks whether that month's
// eligible RPM codes have actually been submitted/claimed, distinct from
// eligibility itself (which is always recomputed from MonitoringSession/
// SyncDay data, never stored).
model BillingPeriodStatus {
  id        String @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  year      Int
  month     Int // 1-12

  markedBilledAt            DateTime?
  markedBilledByStaffUserId String?
  markedBilledByStaffUser   StaffUser? @relation(fields: [markedBilledByStaffUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, year, month])
  @@map("billing_period_statuses")
}

// One row per practice per (calendar-month) billing period — tracks a
// formal RPM billing batch generation, distinct from the live/ad-hoc
// eligibility tracker on the Billing tab. Regenerating a period replaces
// its RpmBillingLine rows rather than creating a second batch, hence the
// unique constraint below.
model BillingBatch {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodStart    DateTime     @db.Date
  periodEnd      DateTime     @db.Date
  generatedAt    DateTime     @default(now())

  generatedByStaffUserId String?
  generatedByStaffUser   StaffUser? @relation(fields: [generatedByStaffUserId], references: [id], onDelete: SetNull)

  lines RpmBillingLine[]

  @@unique([organizationId, periodStart, periodEnd])
  @@map("billing_batches")
}

// One row per billable CPT code per patient per billing period — the
// persisted snapshot an RPM billing CSV export is built from. Never
// computed live; only written by generateMonthlyBatch().
model RpmBillingLine {
  id             String       @id @default(cuid())
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  batchId        String
  batch          BillingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  billingPeriodStart DateTime @db.Date
  billingPeriodEnd   DateTime @db.Date
  cptCode            String // "99453" | "99454" | "99457" | "99458"
  units              Int
  diagnosisCode      String
  diagnosisPointer   String  @default("A")
  placeOfService     String  @default("11")
  modifier           String?

  // Always the supervising physician's NPI (general-supervision billing
  // model) — never the CDCES-RN who performed the underlying work.
  renderingProviderNpi String?

  // Intentionally always null — the practice's own fee schedule populates
  // this on their end, not this app.
  chargeAmount Decimal? @db.Decimal(10, 2)

  billingProviderName  String?
  billingProviderNpi   String?
  billingProviderTaxId String?

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([batchId])
  @@map("rpm_billing_lines")
}

// Patients who didn't meet any billing threshold in a period — logged for
// transparency (why they're missing from the export), never mixed into
// RpmBillingLine.
model RpmExclusion {
  id             String       @id @default(cuid())
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  periodStart    DateTime     @db.Date
  periodEnd      DateTime     @db.Date
  reason         String

  createdAt DateTime @default(now())

  @@index([patientId])
  @@map("rpm_exclusions")
}

// HIPAA-minded access log: who looked at (or acted on) which patient, when.
model AuditLog {
  id          String    @id @default(cuid())
  staffUserId String?
  staffUser   StaffUser? @relation(fields: [staffUserId], references: [id], onDelete: SetNull)
  patientId   String?
  patient     Patient?   @relation(fields: [patientId], references: [id], onDelete: SetNull)

  action    String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([staffUserId])
  @@index([patientId])
  @@index([createdAt])
  @@map("audit_logs")
}
